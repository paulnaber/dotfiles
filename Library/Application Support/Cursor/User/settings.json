    // To improve performance
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1,
        "asvetliakov.vscode-neovim": 1
    },
    // IMPORTANT KEYMAPS
    // ### tabs and windows
    // ctrl (caps) e                   -> open explorer (pref cmd shift e for toggle)
    // ctrl (caps) + h | j | k | l     -> switching between splits
    // shift + h | l                   -> tab switching
    // leader (space) + v | s          -> create splitt
    // leader (space) + tt             -> new tab
    // leader (space) + to             -> close other tabs
    // leader (space) + td             -> close currtent tab
    // leader (space) + w              -> save file
    // ### quickjumps
    // leader (space) h                -> see open tabs - use it with enter to quickly go back to last file (ctrl tab basically)
    // ctrl (caps) + o | i             -> jump back and forth
    // ### Search
    // leader (space) space            -> quick open file search
    // leader (space) + p              -> quick open file search
    // leader (space) /                -> grep search (file content)
    // ### easymotion
    // s                               -> easymotion character find - similar to leap or flash
    // leader + /                      -> easymotion character find - similar to leap - currently disabled for quickopen
    // leader + w                      -> easymotion jump to word - currently disabled for quickopen
    // leader gg                       -> lazygit (lazygit extension required)
    // leader + f                      -> format file
    // leader rn                       -> rename symbol
    "vim.normalModeKeyBindings": [
        {
            "before": ["J"],
            "after": ["5", "j", "z", "z"]
            // "after": ["j", "z", "z"]
            // "after": ["}"]
        },
        {
            "before": ["K"],
            "after": ["5", "k", "z", "z"]
            // "after": ["k", "z", "z"]
            // "after": ["{"]
        },
        {
            "before": ["<Leader>", "j"],
            "after": ["J"]
        },
        // back and forth
        {
            "before": ["<C-i"],
            "after": ["C", "S", "-"]
        },
        {
            "before": ["<C-o"],
            "after": ["C", "-"]
        },
        // SWITCHING BETWEEN SPLITS
        {
            "before": ["<C-h>"], // same as in tmux
            "after": ["<C-w>", "h"] // same as in nvim
        },
        {
            "before": ["<C-j>"], // same as in tmux
            "after": ["<C-w>", "j"] // same as in nvim
        },
        {
            "before": ["<C-k>"], // same as in tmux
            "after": ["<C-w>", "k"] // same as in nvim
        },
        {
            "before": ["<C-l>"], // same as in tmux
            "after": ["<C-w>", "l"] // same as in nvim
        },
        // SPLITTING SCREENS
        {
            "before": ["<C-a>", "%"], // tmux binding
            "after": ["<C-w>", "v"] // nvim binding
        },
        { "before": ["leader", "v"], "commands": [":vsplit"] },
        {
            "before": ["<C-a>", "\""], // tmux binding (doesn not work)
            "after": ["<C-w>", "s"] // nvim binding
        },
        { "before": ["leader", "s"], "commands": [":split"] },
        // SWITCHING BETWEEN TABS
        { "before": ["<S-h>"], "commands": [":bprevious"] },
        { "before": ["<S-l>"], "commands": [":bnext"] },
        {
            "before": ["<Leader>", "t", "t"],
            "commands": [":tabnew"]
        },
        {
            "before": ["<Leader>", "t", "o"],
            "commands": [":tabo"]
        },
        {
            "before": ["<Leader>", "t", "d"],
            "commands": [":tabc"]
        },
        {
            "before": ["leader", "w"],
            "commands": ["workbench.action.files.save"]
        },
        {
            "before": ["<Leader>", "t"],
            "commands": ["workbench.action.gotoSymbol"]
        },
        {
            "before": ["<Leader>", "p"],
            "commands": ["workbench.action.showCommands"]
        },
        // see all open tabs and navigate between them
        {
            "before": ["<Leader>", "tab"],
            "commands": [
                "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup"
            ]
        },
        {
            "before": ["<Leader>", "g", "c", "r"],
            "commands": ["workbench.action.rename"]
        },
        // EXPLORER
        // it is not quite the same as using cmd shift e
        {
            "before": ["<Leader>", "e"],
            "commands": ["workbench.view.explorer"]
        },
        {
            "before": ["<Leader>", "g", "e"],
            "commands": ["workbench.scm.focus"]
        },
        // FIND and SEARCH
        // {
        //     "before": ["<Leader>", "f"],
        //     "commands": ["workbench.view.search"]
        // },
        // fzf search - more like nvim - extension required and some linux tools like fzf
        // quick search - same but without extension and directly by vscode
        // {
        //     "before": ["leader", "space"],
        //     "commands": ["find-it-faster.findFiles"]
        //     // "commands": ["workbench.action.quickTextSearch"]
        // },
        // {
        //     "before": ["leader", "/"],
        //     "commands": ["find-it-faster.findWithinFiles"]
        // },
        // vscode searches
        {
            "before": ["<Leader>", "space"],
            "commands": ["workbench.action.quickOpen"]
        },
        {
            "before": ["<Leader>", "/"],
            "commands": ["workbench.action.quickTextSearch"]
        },
        // LAZYGIT
        {
            "before": ["<Leader>", "g", "g"],
            "commands": ["lazygit.openLazygit"]
        },
        // Refactoring
        {
            "before": ["<Leader>", "r", "n"],
            "commands": ["editor.action.rename"]
        }
    ],
    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": ["K"],
            "commands": ["editor.action.moveLinesUpAction"]
        },
        {
            "before": ["J"],
            "commands": ["editor.action.moveLinesDownAction"]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        // easymotion
        {
            "before": ["s"],
            // "after": ["leader", "leader", "/"]
            // use this for bidirectional easymotion
            "after": ["leader", "leader", "leader", "b", "d", "w"]
        },
        {
            "before": ["u"],
            "commands": ["undo"]
        },
        {
            "before": ["U"],
            "commands": ["redo"]
        },
        {
            "before": ["leader", "f"],
            "commands": ["editor.action.formatDocument"]
        }
    ],
